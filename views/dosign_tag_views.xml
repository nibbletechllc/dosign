<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dosign_tag_list" model="ir.ui.view">
        <field name="name">dosign.tag.list</field>
        <field name="model">dosign.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_dosign_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">dosign.tag</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
