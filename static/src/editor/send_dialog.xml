<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dosign.SendDialog">
        <Dialog title="'Send for signature'" size="'md'">
            <div class="o_dosign_send">
                <div class="mb-3">
                    <label class="form-label fw-bold">Recipients</label>
                    <ul class="list-unstyled mb-0">
                        <li t-foreach="props.signers" t-as="signer" t-key="signer.id" class="small">
                            <i class="fa fa-user-o me-1 text-muted"/>
                            <t t-esc="signer.name"/>
                            <span class="text-muted"> &lt;<t t-esc="signer.email"/>&gt;</span>
                        </li>
                    </ul>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Message <span class="text-muted fw-normal">(optional)</span></label>
                    <textarea class="form-control" rows="3"
                              placeholder="Add a personal note to the request email"
                              t-att-value="state.message"
                              t-on-input="(ev) => state.message = ev.target.value"/>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Expiry date</label>
                        <input type="date" class="form-control"
                               t-att-value="state.expiryDate"
                               t-on-change="(ev) => state.expiryDate = ev.target.value"/>
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">Signing order</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" id="mode_parallel"
                                   t-att-checked="state.signingMode === 'parallel'"
                                   t-on-change="() => state.signingMode = 'parallel'"/>
                            <label class="form-check-label" for="mode_parallel">Parallel (all at once)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" id="mode_sequential"
                                   t-att-checked="state.signingMode === 'sequential'"
                                   t-on-change="() => state.signingMode = 'sequential'"/>
                            <label class="form-check-label" for="mode_sequential">Sequential (in order)</label>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="() => this.confirm()">
                    <i class="fa fa-paper-plane me-1"/> Send
                </button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Cancel</button>
            </t>
        </Dialog>
    </t>

</templates>
