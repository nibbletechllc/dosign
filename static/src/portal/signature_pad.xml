<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dosign.SignaturePad">
        <div class="o_dosign_pad_backdrop" t-on-click.self="() => this.props.onCancel()">
            <div class="o_dosign_pad">
                <div class="o_dosign_pad_head">
                    <strong><t t-esc="props.title or 'Adopt Your Signature'"/></strong>
                    <button class="btn btn-link o_dosign_pad_close p-0"
                            t-on-click="() => this.props.onCancel()">
                        <i class="fa fa-times"/>
                    </button>
                </div>
                <div class="o_dosign_pad_body">
                    <NameAndSignature t-props="nameAndSignatureProps"/>
                    <p class="o_dosign_consent text-muted small mt-2 mb-0">
                        By signing, I agree that the chosen signature/initials will be a
                        valid electronic representation of my hand-written signature/initials
                        for all purposes when it is used on documents, including legally
                        binding contracts.
                    </p>
                </div>
                <div class="o_dosign_pad_foot">
                    <button class="btn btn-secondary me-2"
                            t-on-click="() => this.props.onCancel()">
                        Cancel
                    </button>
                    <button class="btn btn-primary" t-att-disabled="signature.isSignatureEmpty"
                            t-on-click="() => this.confirm()">
                        Adopt &amp; Sign
                    </button>
                </div>
            </div>
        </div>
    </t>

</templates>
