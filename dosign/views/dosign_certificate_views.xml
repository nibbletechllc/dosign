<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dosign_certificate_list" model="ir.ui.view">
        <field name="name">dosign.certificate.list</field>
        <field name="model">dosign.certificate</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'expired'" decoration-warning="state == 'expiring_soon'">
                <field name="name"/>
                <field name="subject"/>
                <field name="valid_to"/>
                <field name="is_default"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'valid'"
                       decoration-warning="state == 'expiring_soon'"
                       decoration-danger="state == 'expired'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_dosign_certificate_form" model="ir.ui.view">
        <field name="name">dosign.certificate.form</field>
        <field name="model">dosign.certificate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Certificate Name"/></h1>
                    </div>
                    <group>
                        <group string="Upload">
                            <field name="p12_file" filename="p12_filename"/>
                            <field name="p12_filename" invisible="1"/>
                            <!-- Write-only: never re-rendered after save (TDD 6.4). -->
                            <field name="p12_password" password="True"/>
                            <field name="is_default"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Metadata">
                            <field name="state" widget="badge"/>
                            <field name="subject"/>
                            <field name="issuer"/>
                            <field name="serial"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dosign_certificate" model="ir.actions.act_window">
        <field name="name">Certificates</field>
        <field name="res_model">dosign.certificate</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
