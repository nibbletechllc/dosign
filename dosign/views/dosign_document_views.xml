<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ List (module home) ============ -->
    <record id="view_dosign_document_list" model="ir.ui.view">
        <field name="name">dosign.document.list</field>
        <field name="model">dosign.document</field>
        <field name="arch" type="xml">
            <list js_class="dosign_document_list" create="false">
                <field name="create_date" string="Date"/>
                <field name="name"/>
                <field name="reference" optional="hide"/>
                <field name="user_id" string="Sent by" widget="many2one_avatar_user"/>
                <field name="signer_count" string="Signers"/>
                <field name="tag_ids" widget="many2many_tags" optional="hide"
                       options="{'color_field': 'color'}"/>
                <field name="progress_label" string="Progress"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'sent'"
                       decoration-warning="state == 'partial'"
                       decoration-success="state == 'signed'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state in ('draft', 'cancelled')"/>
                <button name="action_open_editor" type="object" string="Continue editing"
                        icon="fa-pencil" invisible="state != 'draft'"/>
                <button name="action_resend" type="object" string="Resend"
                        icon="fa-paper-plane" invisible="state not in ('sent', 'partial')"/>
                <button name="action_resend" type="object" string="Send again"
                        icon="fa-refresh" invisible="state != 'expired'"/>
            </list>
        </field>
    </record>

    <!-- ============ Kanban (status board) ============ -->
    <record id="view_dosign_document_kanban" model="ir.ui.view">
        <field name="name">dosign.document.kanban</field>
        <field name="model">dosign.document</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" group_create="false" class="o_kanban_small_column">
                <field name="state"/>
                <field name="progress_label"/>
                <field name="signer_count"/>
                <field name="signed_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_subtitle text-muted">
                                <field name="reference"/>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <span class="badge text-bg-secondary">
                                        <i class="fa fa-users me-1"/>
                                        <field name="progress_label"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============ Form ============ -->
    <record id="view_dosign_document_form" model="ir.ui.view">
        <field name="name">dosign.document.form</field>
        <field name="model">dosign.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_editor" type="object" string="Open Editor"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_send" type="object" string="Send"
                            invisible="state != 'draft'"/>
                    <button name="action_sign_now" type="object" string="Sign Now"
                            invisible="state != 'draft'"/>
                    <button name="action_resend" type="object" string="Resend"
                            invisible="state not in ('sent', 'partial', 'expired')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('signed', 'cancelled')"/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,partial,signed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Document Name"/></h1>
                        <field name="reference" class="text-muted" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="attachment_id" readonly="state != 'draft'"/>
                            <field name="template_id" readonly="state != 'draft'"/>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="expiry_date"/>
                            <field name="progress_label"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Signers" name="signers">
                            <field name="signer_ids" readonly="state not in ('draft', 'sent', 'partial')">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="email" widget="email"/>
                                    <field name="partner_id" optional="hide"/>
                                    <field name="state" widget="badge"/>
                                    <field name="signed_on" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Fields" name="fields">
                            <field name="item_ids" readonly="state != 'draft'">
                                <list>
                                    <field name="field_type_id"/>
                                    <field name="signer_id"/>
                                    <field name="page"/>
                                    <field name="required"/>
                                </list>
                            </field>
                        </page>
                        <page string="Audit Trail" name="audit">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="timestamp"/>
                                    <field name="action"/>
                                    <field name="actor"/>
                                    <field name="signer_id"/>
                                    <field name="ip_address" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Integrity" name="integrity">
                            <group>
                                <field name="sha256_original"/>
                                <field name="sha256_final"/>
                                <field name="certificate_id"/>
                                <field name="completed_attachment_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============ Search ============ -->
    <record id="view_dosign_document_search" model="ir.ui.view">
        <field name="name">dosign.document.search</field>
        <field name="model">dosign.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="reference"/>
                <field name="signer_ids" string="Signer"
                       filter_domain="['|', ('signer_ids.name', 'ilike', self), ('signer_ids.email', 'ilike', self)]"/>
                <field name="tag_ids"/>
                <filter name="my_documents" string="My Documents"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="sent" string="To Sign" domain="[('state', '=', 'sent')]"/>
                <filter name="partial" string="Partially Signed" domain="[('state', '=', 'partial')]"/>
                <filter name="signed" string="Signed" domain="[('state', '=', 'signed')]"/>
                <filter name="expired" string="Expired" domain="[('state', '=', 'expired')]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="Sent by" context="{'group_by': 'user_id'}"/>
                    <filter name="group_template" string="Template" context="{'group_by': 'template_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============ Action ============ -->
    <record id="action_dosign_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">dosign.document</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_dosign_document_search"/>
        <field name="context">{'search_default_my_documents': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload a PDF to start signing
            </p>
            <p>
                Place signature and data fields, then send the document to your
                signers for a frictionless, legally meaningful e-signature flow.
            </p>
        </field>
    </record>
</odoo>
