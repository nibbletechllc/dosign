<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dosign.FieldChip">
        <div class="o_dosign_chip" t-att-style="style"
             t-on-pointerdown="(ev) => this.onPointerDown(ev, 'move')">
            <span class="o_dosign_chip_label">
                <t t-esc="props.label"/>
            </span>
            <button class="o_dosign_chip_del" t-on-pointerdown.stop=""
                    t-on-click.stop="() => this.props.onRemove()" title="Delete">
                <i class="fa fa-times"/>
            </button>
            <span class="o_dosign_chip_resize"
                  t-on-pointerdown="(ev) => this.onPointerDown(ev, 'resize')"/>
        </div>
    </t>

</templates>
