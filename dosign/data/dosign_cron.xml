<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_dosign_expire_documents" model="ir.cron">
            <field name="name">Dosign: Expire documents</field>
            <field name="model_id" ref="model_dosign_document"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_documents()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_dosign_send_reminders" model="ir.cron">
            <field name="name">Dosign: Send reminders</field>
            <field name="model_id" ref="model_dosign_document"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_dosign_certificate_watch" model="ir.cron">
            <field name="name">Dosign: Certificate watch</field>
            <field name="model_id" ref="model_dosign_certificate"/>
            <field name="state">code</field>
            <field name="code">model._cron_certificate_watch()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
